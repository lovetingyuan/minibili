{
  "name": "minibili-monorepo",
  "private": true,
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "format": "oxfmt .",
    "lint": "npm run lint --workspaces --if-present",
    "knip:app": "knip --workspace @minibili/app",
    "android": "npm run android -w=@minibili/app",
    "build:preview": "npm run build:android:preview -w=@minibili/app",
    "update": "npm run update -w=@minibili/app",
    "server": "npm run dev -w=@minibili/server",
    "deploy": "npm run deploy -w=@minibili/server",
    "build": "npm run build:android -w=@minibili/app"
  },
  "dependencies": {},
  "devDependencies": {
    "knip": "^6.0.1",
    "oxfmt": "latest",
    "oxlint": "^1.56.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "react-native-reanimated": "4.2.1",
    "react-native-worklets": "0.7.2"
  }
}
