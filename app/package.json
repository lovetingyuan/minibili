  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/core": "^7.25.2",
    "@types/crypto-js": "^4.2.2",
    "@types/he": "^1.2.3",
    "@types/react": "~19.2.10",
    "@types/throttle-debounce": "^5.0.2",
