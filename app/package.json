{
  "name": "@minibili/app",
  "version": "0.7.0",
  "gitHead": "7fea38d",
  "description": "minimum bilibili apk",
  "homepage": "https://lovetingyuan.github.io/minibili/",
  "repository": "github:lovetingyuan/minibili",
  "files": [
    "apk",
    "docs"
  ],
  "main": "index.js",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "expo start",
    "android": "adb devices -l && npx expo start --android",
    "ios": "adb devices -l && npx expo start --ios",
    "web": "expo start --web",
    "build:android": "zx scripts/build.mjs",
    "build:android:preview": "cross-env APP_VARIANT=preview npx --yes eas-cli@latest build --platform android --profile preview --non-interactive",
    "update": "zx scripts/hot-update.mjs",
    "doctor": "npx -y expo-doctor@latest",
    "test": "npx vitest run",
    "lint": "oxlint . --react-plugin --fix --fix-suggestions",
    "update-expo": "npm i -g eas-cli && npm install expo && npx expo install --fix && npm run doctor",
    "bundle-analyze": "npx --yes react-native-bundle-visualizer --platform android --entry-file index.js --expo true"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/hooks": "^100.1.0",
    "@react-native-community/netinfo": "11.5.2",
