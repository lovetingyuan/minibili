{
  "name": "@minibili/app",
  "version": "0.7.0",
  "description": "minimum bilibili apk",
  "main": "index.js",
  "files": [
    "apk",
    "docs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": "github:lovetingyuan/minibili",
  "homepage": "https://lovetingyuan.github.io/minibili/",
  "scripts": {
    "start": "expo start",
    "android": "adb devices -l && npx expo start --android",
    "tw": "npx react-native-tailwindcss-start",
    "tw:dev": "npx yalc update && npm run tw -- --write=styles.tw.css",
    "ios": "adb devices -l && npx expo start --ios",
    "web": "expo start --web",
    "build:android": "zx scripts/build.mjs",
    "build:android:preview": "cross-env APP_VARIANT=preview eas build --platform android --profile preview --non-interactive",
    "update": "zx scripts/hot-update.mjs",
    "doctor": "npx -y expo-doctor@latest",
    "format": "npx prettier src scripts --write",
    "test": "npx vitest run",
    "lint": "expo lint",
    "update-expo": "npm i -g eas-cli && npm install expo && npx expo install --fix && npm run doctor",
    "bundle-analyze": "npx react-native-bundle-visualizer --platform android --entry-file index.js --expo true"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/hooks": "^100.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-vector-icons/material-icons": "^12.4.0",
    "@react-navigation/elements": "^2.5.2",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "@rneui/base": "^5.0.0",
    "@rneui/themed": "^5.0.0",
    "@shopify/flash-list": "2.0.2",
    "clsx": "^2.1.0",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "he": "^1.2.0",
    "p-queue": "6.6.2",
    "react": "19.1.0",
    "react-atomic-context": "^3.0.0-0",
    "react-native": "0.81.5",
    "react-native-error-boundary": "^2.0.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-simple-toast": "^3.3.2",
    "react-native-webview": "13.15.0",
    "swr": "^2.3.4",
    "throttle-debounce": "^5.0.2",
    "zod": "^3.24.2"
  },
  "overrides": {
    "react-test-renderer": "19.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@tingyuan/react-native-tailwindcss": "^0.0.18",
    "@types/crypto-js": "^4.2.2",
    "@types/he": "^1.2.3",
    "@types/react": "~19.1.0",
    "@types/throttle-debounce": "^5.0.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "cross-env": "^7.0.3",
    "download-cli": "^1.1.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "open": "8.4.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^5.0.5",
    "semver": "^7.5.1",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2",
    "vitest": "^3.0.9",
    "wrangler": "^4.6.0",
    "zx": "^8.4.1"
  },
  "knip": {
    "$schema": "https://unpkg.com/knip/schema.json",
    "entry": [
      "./index.js",
      "./website/main.js"
    ],
    "project": [
      "src/**",
      "scripts/**"
    ]
  },
  "config": {
    "versionCode": 73,
    "changelog": "update expo  动态页面改版"
  },
  "gitHead": "7fea38d"
}
