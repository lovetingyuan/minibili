    "oxlint": "^1.56.0",
    "rimraf": "^5.0.5",
    "semver": "^7.5.1",
    "zx": "^8.4.1"
  },
  "overrides": {
    "react-test-renderer": "19.2.0"
  },
  "config": {
    "changelog": "update expo  动态页面改版",
    "versionCode": 73
  }
