    "@react-native-vector-icons/ionicons": "^12.4.0",
    "@react-native-vector-icons/material-design-icons": "^12.4.0",
    "@react-native-vector-icons/material-icons": "^12.4.0",
    "@react-native-vector-icons/octicons": "^20.3.0",
    "@react-navigation/elements": "^2.5.2",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "@rneui/base": "^5.0.0",
    "@rneui/themed": "^5.0.0",
    "@shopify/flash-list": "2.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "clsx": "^2.1.0",
    "crypto-js": "^4.2.0",
    "expo": "^55.0.0",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.9",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-keep-awake": "~55.0.4",
    "expo-splash-screen": "~55.0.12",
